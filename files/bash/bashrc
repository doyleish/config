#K8s workflow
# ===Start===
alias kkns='kubectl get ns -o name | cut -d/ -f2 | fzf | xargs kubectl config set-context --current --namespace'
alias kkc='kubectl config get-contexts -o name | fzf | xargs kubectl config use-context'
kkget () {
    kubectl get $1 -o name | fzf | xargs kubectl get -o yaml
}
kkdesc () {
    kubectl get $1 -o name | fzf | xargs kubectl describe
}
