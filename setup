#!/bin/bash
SCDIR=$(dirname ${BASH_SOURCE[0]})
cd $SCDIR
CFGDIR=$(pwd)

## link up dotfiles
ln -sf $CFGDIR/files/vim $HOME/.vimrc
ln -sf $CFGDIR/files/tmux $HOME/.tmux.conf
ln -sf $CFGDIR/files/gitconfig $HOME/.gitconfig

## bash
ln -sf $CFGDIR/files/bash/profile $HOME/.profile
ln -sf $CFGDIR/files/bash/bash_profile $HOME/.bash_profile
ln -sf $CFGDIR/files/bash/bashrc $HOME/.bashrc

## misc setup
if [ ! -d ~/.vim/bundle/Vundle.vim ]; then 
    git clone https://github.com/VundleVim/Vundle.vim.git ~/.vim/bundle/Vundle.vim
fi
